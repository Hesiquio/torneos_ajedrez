{
  "name": "torneos-ajedrez",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev:frontend": "vite",
    "dev:backend": "nodemon --watch server --exec ts-node server/index.ts",
    "build:frontend": "vite build",
    "build:backend": "tsc --project tsconfig.server.json",
    "build": "npm run build:frontend && npm run build:backend",
    "start": "cross-env NODE_ENV=production node dist-server/index.js",
    "db:init": "ts-node server/init-db.ts"
  },
  "dependencies": {
    "@libsql/client": "^0.6.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "lucide-react": "^0.395.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "cross-env": "^7.0.3",
    "nodemon": "^3.1.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5",
    "vite": "^5.2.11"
  }
}
